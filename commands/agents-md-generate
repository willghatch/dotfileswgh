#!/usr/bin/env python3
"""
agents-md-generate - Generate AGENTS.md by concatenating segments

Segments are .md or .prog files found in (per location, dev-type paths precede base path):
  1. <git-root>/.git/agent-files/config/agents-md-generate/<dev-type>/{default,non-default}/
  2. <git-root>/.git/agent-files/config/agents-md-generate/{default,non-default}/
  3. XDG_CONFIG_HOME/agents-md-generate/<dev-type>/{default,non-default}/
  4. XDG_CONFIG_HOME/agents-md-generate/{default,non-default}/
  5. Each XDG_CONFIG_DIRS entry (same pattern)

Dev types come from --dev-type flags (repeatable, highest priority), the
DEV_TYPES environment variable (comma-separated), and
.git/agent-files/dev-types.json (a JSON list of strings, lowest priority).
All sources are merged and deduplicated.  Multiple dev types are searched in
the order given, so the first --dev-type has the highest priority.

Earlier search paths take priority (first found wins for a given segment name).
When the same segment name exists as both .md and .prog in the same directory,
.prog takes priority.
"""

import argparse
import os
import sys
from pathlib import Path

sys.path.insert(0, os.path.join(os.path.dirname(os.path.abspath(__file__)), 'agent-files-pylib'))
from agent_files_common import (
    find_files_by_extension,
    find_git_root,
    find_link_files,
    gather_dev_types,
    get_base_search_paths,
    get_raw_location_bases,
    get_state_file_path,
    load_state,
    read_file_or_exec,
    resolve_links,
    save_state,
)

PROG_NAME = "agents-md-generate"
CONFIG_NAME = "agents-md-generate"


def find_segments(base_paths, subdir):
    """Find all segments in the given subdirectory across all base paths.

    Returns an ordered dict of name -> Path, with earlier paths taking priority.
    Segments within a single directory are sorted alphabetically by name.
    When both .md and .prog exist for the same name in the same directory,
    .prog takes priority.
    """
    return find_files_by_extension(base_paths, [".md", ".prog"], subdir)


def find_all_segments(base_paths):
    """Find default and non-default segments, resolving dev-type links.

    Returns (default_segments, non_default_segments) dicts of name -> Path.
    Link files (``link:NAME``) in default/ promote non-default items into
    the default set.
    """
    default_segments = find_segments(base_paths, "default")
    non_default_segments = find_segments(base_paths, "non-default")
    default_links = find_link_files(base_paths, "default")
    resolve_links(default_segments, default_links, non_default_segments, PROG_NAME)
    return default_segments, non_default_segments


def read_segment(path, dev_types, git_root):
    """Read a segment's content.  For .md files, read text; for .prog files, execute.

    Returns the content string, or None if execution failed.
    """
    env_extras = {"DEV_TYPES": ",".join(dev_types)}
    if git_root:
        env_extras["AGENT_WORK_GIT_ROOT"] = str(git_root)
    content, error = read_file_or_exec(path, PROG_NAME, env_extras)
    if error:
        print(
            f"{PROG_NAME}: error: {error}",
            file=sys.stderr,
        )
        return None
    return content


def list_dev_types(git_root):
    """List available dev-type directory names from all base search paths."""
    bases = get_raw_location_bases(CONFIG_NAME, git_root)
    dev_types = set()
    skip_names = {"default", "non-default"}
    for base in bases:
        if not base.is_dir():
            continue
        for entry in base.iterdir():
            if entry.is_dir() and entry.name not in skip_names:
                dev_types.add(entry.name)
    return sorted(dev_types)


def main():
    parser = argparse.ArgumentParser(
        description="Generate AGENTS.md by concatenating segment files.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    parser.add_argument(
        "--add", "-a",
        action="append",
        metavar="SEGMENT",
        default=[],
        dest="add",
        help="Add a non-default segment by name (can be repeated)",
    )
    parser.add_argument(
        "--omit", "-o",
        action="append",
        metavar="SEGMENT",
        default=[],
        dest="omit",
        help="Omit a default segment by name (can be repeated)",
    )
    parser.add_argument(
        "--list-default",
        action="store_true",
        help="List available default segment names (for shell completion)",
    )
    parser.add_argument(
        "--list-non-default",
        action="store_true",
        help="List available non-default segment names (for shell completion)",
    )
    parser.add_argument(
        "--list-all",
        action="store_true",
        help="List all segment names with type annotation (for shell completion)",
    )
    parser.add_argument(
        "--list-segments",
        action="store_true",
        help="List all segment names (for shell completion with --reset)",
    )
    parser.add_argument(
        "--list-dev-types",
        action="store_true",
        help="List available dev-type names",
    )
    parser.add_argument(
        "--no-preamble",
        action="store_true",
        help="Suppress the command preamble written to stderr",
    )
    parser.add_argument(
        "--dev-type", "-d",
        action="append",
        metavar="TYPE",
        default=[],
        dest="dev_types",
        help="Add a dev-type search layer (can be repeated; overrides $DEV_TYPES)",
    )
    parser.add_argument(
        "--show-paths",
        action="store_true",
        help="Show the search paths being used and exit",
    )
    parser.add_argument(
        "--save-state",
        action="store_true",
        help="Save current config to state file for later regeneration",
    )
    parser.add_argument(
        "--from-state",
        action="store_true",
        help="Load state from state file (falls back to defaults if no state)",
    )
    parser.add_argument(
        "--from-state-strict",
        action="store_true",
        help="Load state from state file (error if no state file exists)",
    )
    parser.add_argument(
        "--update",
        action="store_true",
        help="With --save-state, modify existing state incrementally",
    )
    parser.add_argument(
        "--reset",
        action="append",
        metavar="SEGMENT",
        default=[],
        help="With --update, return a segment to its category default (can be repeated)",
    )
    parser.add_argument(
        "--delete-state",
        action="store_true",
        help="Delete the state file and exit",
    )

    args = parser.parse_args()

    git_root = find_git_root()

    # Handle --delete-state: delete and exit immediately
    if args.delete_state:
        state_path = get_state_file_path(CONFIG_NAME, git_root)
        if state_path and state_path.is_file():
            state_path.unlink()
        return

    # Combine --dev-type flags, $DEV_TYPES env var, and dev-types.json
    dev_types = gather_dev_types(args.dev_types, git_root, PROG_NAME)

    # Handle --list-dev-types before search path expansion
    if args.list_dev_types:
        for dt in list_dev_types(git_root):
            print(dt)
        return

    # Handle --from-state / --from-state-strict: load state and merge with CLI flags
    if args.from_state or args.from_state_strict:
        state_path = get_state_file_path(CONFIG_NAME, git_root)
        state = load_state(state_path)
        if state is None:
            if args.from_state_strict:
                print(
                    f"{PROG_NAME}: error: no state file found (use --save-state to create one)",
                    file=sys.stderr,
                )
                sys.exit(1)
            # --from-state: fall back to defaults silently
        else:
            # Merge state dev_types: CLI --dev-type prepends, then state, then env
            state_dev_types = state.get("dev_types", [])
            # dev_types already has CLI flags + env; prepend state between them
            # Actually: CLI flags first, then state, then env (deduped)
            merged_dev_types = list(args.dev_types)
            for dt in state_dev_types:
                if dt not in merged_dev_types:
                    merged_dev_types.append(dt)
            for env_dt in os.environ.get("DEV_TYPES", "").split(","):
                env_dt = env_dt.strip()
                if env_dt and env_dt not in merged_dev_types:
                    merged_dev_types.append(env_dt)
            dev_types = merged_dev_types

            # Merge added/omitted: CLI extends state
            state_added = state.get("added", [])
            state_omitted = state.get("omitted", [])
            for name in state_added:
                if name not in args.add:
                    args.add.append(name)
            for name in state_omitted:
                if name not in args.omit:
                    args.omit.append(name)

    base_paths = get_base_search_paths(CONFIG_NAME, dev_types, git_root)

    if args.show_paths:
        for p in base_paths:
            exists = " (exists)" if p.exists() else ""
            print(f"  {p}{exists}")
        return

    default_segments, non_default_segments = find_all_segments(base_paths)

    # Completion / listing modes -- output to stdout and exit
    if args.list_default:
        for name in sorted(default_segments):
            print(name)
        return

    if args.list_non_default:
        for name in sorted(non_default_segments):
            print(name)
        return

    if args.list_all:
        for name in sorted(default_segments):
            print(f"{name}\tdefault")
        for name in sorted(non_default_segments):
            print(f"{name}\tnon-default")
        return

    if args.list_segments:
        all_names = sorted(set(list(default_segments.keys()) + list(non_default_segments.keys())))
        for name in all_names:
            print(name)
        return

    # Handle --save-state with --update: load existing state and apply modifications
    if args.save_state and args.update:
        state_path = get_state_file_path(CONFIG_NAME, git_root)
        state = load_state(state_path)
        if state is not None:
            existing_added = set(state.get("added", []))
            existing_omitted = set(state.get("omitted", []))
            existing_dev_types = list(state.get("dev_types", []))

            # Apply --reset: remove from both added and omitted
            for name in args.reset:
                existing_added.discard(name)
                existing_omitted.discard(name)

            # Apply --add: add non-default or re-include previously omitted default
            for name in args.add:
                existing_omitted.discard(name)
                if name in non_default_segments:
                    existing_added.add(name)

            # Apply --omit: omit default or remove previously added non-default
            for name in args.omit:
                existing_added.discard(name)
                if name in default_segments:
                    existing_omitted.add(name)

            # Merge dev types: CLI flags prepend to existing
            merged_dev_types = list(args.dev_types)
            for dt in existing_dev_types:
                if dt not in merged_dev_types:
                    merged_dev_types.append(dt)
            for env_dt in os.environ.get("DEV_TYPES", "").split(","):
                env_dt = env_dt.strip()
                if env_dt and env_dt not in merged_dev_types:
                    merged_dev_types.append(env_dt)
            dev_types = merged_dev_types

            # Replace args for the rest of processing
            args.add = sorted(existing_added)
            args.omit = sorted(existing_omitted)

            # Recompute base_paths and segments with updated dev_types
            base_paths = get_base_search_paths(CONFIG_NAME, dev_types, git_root)
            default_segments, non_default_segments = find_all_segments(base_paths)

    # Validate --add segment names
    errors = False
    for name in args.add:
        if name not in non_default_segments:
            print(
                f"{PROG_NAME}: error: non-default segment '{name}' not found",
                file=sys.stderr,
            )
            errors = True
    if errors:
        sys.exit(1)

    # Warn about unknown --omit segment names
    for name in args.omit:
        if name not in default_segments:
            print(
                f"{PROG_NAME}: warning: default segment '{name}' not found (nothing to omit)",
                file=sys.stderr,
            )

    # Write the reproducing command to stderr
    if not args.no_preamble:
        cmd_parts = [PROG_NAME]
        for name in args.omit:
            cmd_parts.extend(["--omit", name])
        for name in args.add:
            cmd_parts.extend(["--add", name])
        #print(f"# Regenerate with: {' '.join(cmd_parts)}", file=sys.stderr)

    # Collect segments to emit: defaults (minus omitted) then explicitly added non-defaults
    omit_set = set(args.omit)
    to_emit = []
    for name in sorted(default_segments):
        if name not in omit_set:
            to_emit.append((name, default_segments[name]))
    for name in args.add:
        to_emit.append((name, non_default_segments[name]))

    # Concatenate and write to stdout
    for i, (name, path) in enumerate(to_emit):
        content = read_segment(path, dev_types, git_root)
        if content is None:
            # .prog execution failed, skip this segment
            continue
        if i > 0:
            sys.stdout.write("\n")
        sys.stdout.write(content)
        if not content.endswith("\n"):
            sys.stdout.write("\n")

    # Save state if requested
    if args.save_state:
        state_path = get_state_file_path(CONFIG_NAME, git_root)
        if state_path is None:
            print(
                f"{PROG_NAME}: error: cannot save state (not in a git repo)",
                file=sys.stderr,
            )
            sys.exit(1)
        save_state(state_path, dev_types, args.add, args.omit)


if __name__ == "__main__":
    main()
