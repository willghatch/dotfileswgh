#!/usr/bin/env python3
"""Modify git commit metadata (author, committer, dates) without creating a new commit.

Amends metadata on an existing commit (typically HEAD) in place, providing an
ergonomic CLI so you don't have to remember GIT_AUTHOR_DATE, GIT_COMMITTER_DATE,
GIT_AUTHOR_NAME, GIT_AUTHOR_EMAIL, GIT_COMMITTER_NAME, GIT_COMMITTER_EMAIL.

Common use case: after squashing commits for a PR, the squashed commit gets
the datetime of the earliest commit.  This tool lets you set it to e.g. the
latest pre-squash commit's datetime, the current time, or an arbitrary datetime.
"""

import argparse
import os
import re
import subprocess
import sys
from datetime import datetime, timezone


def run_git(*args, check=True, capture=True):
    """Run a git command and return stdout, stripped."""
    cmd = ["git"] + list(args)
    result = subprocess.run(
        cmd,
        capture_output=capture,
        text=True,
        check=check,
    )
    if capture:
        return result.stdout.strip()
    return ""


def run_git_rc(*args):
    """Run a git command and return (returncode, stdout)."""
    cmd = ["git"] + list(args)
    result = subprocess.run(cmd, capture_output=True, text=True)
    return result.returncode, result.stdout.strip()


def is_git_ref(value):
    """Check if a string looks like it could be a git ref."""
    if value.lower() == "now":
        return False
    # Try to resolve it as a git ref
    rc, _ = run_git_rc("rev-parse", "--verify", f"{value}^{{commit}}")
    return rc == 0


def resolve_date(value):
    """Resolve a date argument to a date string.

    If value is a git ref, extract the author date from that commit.
    If value is 'now', return the current time.
    Otherwise, return the value as-is (assumed to be a parseable date string).
    """
    if value.lower() == "now":
        return datetime.now(timezone.utc).astimezone().isoformat()

    if is_git_ref(value):
        return run_git("log", "-1", "--format=%aI", value)

    # Assume it's a date string; let git validate it later
    return value


def parse_author_string(value):
    """Parse 'Name <email>' into (name, email).

    Returns (name, email) or raises ValueError.
    """
    match = re.match(r"^(.+?)\s*<([^>]+)>$", value.strip())
    if not match:
        raise ValueError(
            f"Invalid author/committer format: {value!r}\n"
            f"Expected: \"Name <email>\""
        )
    return match.group(1).strip(), match.group(2).strip()


def resolve_author(value):
    """Resolve an --author argument to (name, email).

    If value is a git ref, extract the author identity from that commit.
    Otherwise, parse it as a 'Name <email>' string.
    """
    if is_git_ref(value):
        identity = run_git("log", "-1", "--format=%an <%ae>", value)
        return parse_author_string(identity)
    return parse_author_string(value)


def resolve_committer(value):
    """Resolve a --committer argument to (name, email).

    If value is a git ref, extract the committer identity from that commit.
    Otherwise, parse it as a 'Name <email>' string.
    """
    if is_git_ref(value):
        identity = run_git("log", "-1", "--format=%cn <%ce>", value)
        return parse_author_string(identity)
    return parse_author_string(value)


def get_commit_meta(commit_ref):
    """Get metadata for a commit.

    Returns dict with keys: hash, author_name, author_email, author_date,
    committer_name, committer_email, committer_date, subject.
    """
    fmt = "%H%n%an%n%ae%n%aI%n%cn%n%ce%n%cI%n%s"
    output = run_git("log", "-1", f"--format={fmt}", commit_ref)
    lines = output.split("\n")
    return {
        "hash": lines[0],
        "author_name": lines[1],
        "author_email": lines[2],
        "author_date": lines[3],
        "committer_name": lines[4],
        "committer_email": lines[5],
        "committer_date": lines[6],
        "subject": lines[7],
    }


def show_commit_meta(meta):
    """Display commit metadata."""
    short_hash = meta["hash"][:7]
    print(f"Commit:     {short_hash} {meta['subject']}")
    print(f"Author:     {meta['author_name']} <{meta['author_email']}>")
    print(f"AuthorDate: {meta['author_date']}")
    print(f"Commit:     {meta['committer_name']} <{meta['committer_email']}>")
    print(f"CommitDate: {meta['committer_date']}")


def check_staged_changes():
    """Warn if there are staged changes that would be included in the amend."""
    rc, output = run_git_rc("diff", "--cached", "--quiet")
    if rc != 0:
        print(
            "WARNING: You have staged changes. git commit --amend will include "
            "them in the amended commit.",
            file=sys.stderr,
        )
        print(
            "Unstage them first with 'git reset HEAD' if this is not intended.",
            file=sys.stderr,
        )
        print(file=sys.stderr)
        response = input("Continue anyway? [y/N] ")
        if response.lower() not in ("y", "yes"):
            print("Aborted.", file=sys.stderr)
            sys.exit(1)


def resolve_commit(commit_ref):
    """Resolve a commit ref and verify it exists. Returns the full hash."""
    rc, full_hash = run_git_rc("rev-parse", "--verify", f"{commit_ref}^{{commit}}")
    if rc != 0:
        print(f"Error: '{commit_ref}' is not a valid commit.", file=sys.stderr)
        sys.exit(1)
    return full_hash


def is_head(commit_hash):
    """Check if a commit hash is the current HEAD."""
    head_hash = run_git("rev-parse", "HEAD")
    return commit_hash == head_hash


def ensure_clean_worktree_for_history_rewrite():
    """Require a clean index and working tree before rewriting non-HEAD history."""
    rc, _ = run_git_rc("diff", "--quiet")
    if rc != 0:
        print(
            "Error: you have unstaged changes.\n"
            "Editing a non-HEAD commit rewrites history and requires a clean "
            "working tree.",
            file=sys.stderr,
        )
        sys.exit(1)

    rc, _ = run_git_rc("diff", "--cached", "--quiet")
    if rc != 0:
        print(
            "Error: you have staged changes.\n"
            "Editing a non-HEAD commit rewrites history and requires a clean "
            "index.",
            file=sys.stderr,
        )
        sys.exit(1)


def ensure_commit_is_ancestor_of_head(commit_hash):
    """Require the target commit to be an ancestor of the current HEAD."""
    rc, current_ref = run_git_rc("symbolic-ref", "--quiet", "--short", "HEAD")
    current_target = current_ref if rc == 0 else "detached HEAD"

    rc, _ = run_git_rc("merge-base", "--is-ancestor", commit_hash, "HEAD")
    if rc == 0:
        return

    if current_target == "detached HEAD":
        print(
            f"Error: commit {commit_hash[:7]} is not an ancestor of the "
            "current detached HEAD.",
            file=sys.stderr,
        )
    else:
        print(
            f"Error: commit {commit_hash[:7]} is not in the current branch "
            f"'{current_target}'.",
            file=sys.stderr,
        )
    sys.exit(1)


def get_distance_from_head(commit_hash):
    """Return the number of commits between commit_hash and HEAD (exclusive).

    HEAD itself returns 0.  HEAD~1 returns 1.  Errors if commit_hash is not
    an ancestor of HEAD (or HEAD itself).
    """
    head_hash = run_git("rev-parse", "HEAD")
    if commit_hash == head_hash:
        return 0
    rc, count_str = run_git_rc("rev-list", "--count", f"{commit_hash}..HEAD")
    if rc != 0:
        print(
            f"Error: could not compute distance from HEAD for {commit_hash[:7]}.",
            file=sys.stderr,
        )
        sys.exit(1)
    return int(count_str)


def get_sign_off_line(name, email):
    """Return the canonical Signed-off-by trailer line."""
    return f"Signed-off-by: {name} <{email}>"


def get_git_user():
    """Get the current git user name and email from config.

    Returns (name, email).  Exits with an error if either is not configured.
    """
    rc_name, name = run_git_rc("config", "user.name")
    rc_email, email = run_git_rc("config", "user.email")
    if rc_name != 0 or not name:
        print(
            "Error: git user.name is not configured.\n"
            "Set it with: git config --global user.name 'Your Name'",
            file=sys.stderr,
        )
        sys.exit(1)
    if rc_email != 0 or not email:
        print(
            "Error: git user.email is not configured.\n"
            "Set it with: git config --global user.email 'you@example.com'",
            file=sys.stderr,
        )
        sys.exit(1)
    return name, email


def get_commit_body(commit_ref):
    """Return the full commit message body (subject + body), unstripped."""
    result = subprocess.run(
        ["git", "log", "-1", "--format=%B", commit_ref],
        capture_output=True,
        text=True,
        check=True,
    )
    # %B includes a trailing newline added by git; preserve internal content
    return result.stdout


def commit_has_sign_off(commit_ref, sign_off_line):
    """Return True if the commit message already contains the sign-off line."""
    body = get_commit_body(commit_ref)
    # Match the sign-off line on a line by itself (case-insensitive for the trailer key)
    pattern = re.compile(
        r"^" + re.escape(sign_off_line) + r"\s*$",
        re.MULTILINE | re.IGNORECASE,
    )
    return bool(pattern.search(body))


def add_sign_off_to_message(body, sign_off_line):
    """Return the commit message with the sign-off line added at the end.

    Ensures exactly one blank line separates the last paragraph from the
    trailer block, matching the git convention.
    """
    # Strip trailing whitespace/newlines from the body
    stripped = body.rstrip()
    return stripped + "\n\n" + sign_off_line + "\n"


def remove_sign_off_from_message(body, sign_off_line):
    """Return the commit message with the sign-off line removed."""
    pattern = re.compile(
        r"^" + re.escape(sign_off_line) + r"\s*\n?",
        re.MULTILINE | re.IGNORECASE,
    )
    new_body = pattern.sub("", body)
    # Clean up any trailing blank lines left behind
    new_body = new_body.rstrip() + "\n"
    return new_body


def build_amend_plan(args, old_meta, new_message=None):
    """Resolve requested changes into amend arguments, environment, and projection.

    If new_message is provided, the commit message is replaced with it.
    """
    env = os.environ.copy()
    if new_message is not None:
        amend_args = ["commit", "--amend", "--allow-empty", "--message", new_message]
    else:
        amend_args = ["commit", "--amend", "--no-edit", "--allow-empty"]
    projected = dict(old_meta)

    new_author_date = None
    new_committer_date = None

    if args.date:
        resolved = resolve_date(args.date)
        new_author_date = resolved
        new_committer_date = resolved

    if args.author_date:
        new_author_date = resolve_date(args.author_date)

    if args.committer_date:
        new_committer_date = resolve_date(args.committer_date)

    if new_author_date:
        # GIT_AUTHOR_DATE env var is ignored by git commit --amend;
        # must use the --date flag instead.
        amend_args.extend(["--date", new_author_date])
        projected["author_date"] = new_author_date

    if new_committer_date:
        env["GIT_COMMITTER_DATE"] = new_committer_date
        projected["committer_date"] = new_committer_date

    new_author_name = None
    new_author_email = None

    if args.author:
        new_author_name, new_author_email = resolve_author(args.author)

    if new_author_name and new_author_email:
        amend_args.extend(["--author", f"{new_author_name} <{new_author_email}>"])
        projected["author_name"] = new_author_name
        projected["author_email"] = new_author_email

    new_committer_name = None
    new_committer_email = None

    if args.committer:
        new_committer_name, new_committer_email = resolve_committer(args.committer)

    if new_committer_name:
        env["GIT_COMMITTER_NAME"] = new_committer_name
        projected["committer_name"] = new_committer_name

    if new_committer_email:
        env["GIT_COMMITTER_EMAIL"] = new_committer_email
        projected["committer_email"] = new_committer_email

    # When changing author date but not committer date, we still need to
    # preserve the original committer date, because git commit --amend
    # resets committer date to now by default.
    if new_author_date and not new_committer_date:
        env["GIT_COMMITTER_DATE"] = old_meta["committer_date"]

    # When changing committer identity but not committer date, preserve
    # the original committer date.
    if (
        (new_committer_name or new_committer_email)
        and not new_committer_date
        and not new_author_date
    ):
        env["GIT_COMMITTER_DATE"] = old_meta["committer_date"]

    # When changing only the author (not committer), also preserve
    # committer date.
    if (
        new_author_name
        and not new_committer_name
        and not new_committer_email
        and not new_committer_date
        and not new_author_date
    ):
        env["GIT_COMMITTER_DATE"] = old_meta["committer_date"]

    # When only the message changes (sign-off), preserve committer date.
    if (
        new_message is not None
        and not new_author_date
        and not new_committer_date
        and not new_author_name
        and not new_committer_name
        and not new_committer_email
    ):
        env["GIT_COMMITTER_DATE"] = old_meta["committer_date"]

    return amend_args, env, projected


def show_changes(old_meta, new_meta):
    """Print a summary of which metadata fields changed."""
    changes = []
    if old_meta["author_date"] != new_meta["author_date"]:
        changes.append("author date")
    if old_meta["committer_date"] != new_meta["committer_date"]:
        changes.append("committer date")
    if old_meta["author_name"] != new_meta["author_name"] or old_meta["author_email"] != new_meta["author_email"]:
        changes.append("author")
    if old_meta["committer_name"] != new_meta["committer_name"] or old_meta["committer_email"] != new_meta["committer_email"]:
        changes.append("committer")

    if changes:
        print(f"\nChanged: {', '.join(changes)}")
    else:
        print("\nNo metadata was changed.")


def amend_head_with_plan(amend_args, env):
    """Amend HEAD using the provided git arguments and environment."""
    result = subprocess.run(
        ["git"] + amend_args,
        env=env,
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        print("Error: git commit --amend failed:", file=sys.stderr)
        print(result.stderr, file=sys.stderr)
        sys.exit(1)


def rewrite_non_head_commit(commit_hash, amend_args, env):
    """Rewrite a non-HEAD commit, then rebase descendants onto the new commit."""
    original_head = run_git("rev-parse", "HEAD")
    rc, original_branch = run_git_rc("symbolic-ref", "--quiet", "--short", "HEAD")
    original_target = original_branch if rc == 0 else original_head

    checkout_target = subprocess.run(
        ["git", "checkout", "--detach", commit_hash],
        capture_output=True,
        text=True,
    )
    if checkout_target.returncode != 0:
        print("Error: failed to check out target commit:", file=sys.stderr)
        print(checkout_target.stderr, file=sys.stderr)
        sys.exit(1)

    amend_head_with_plan(amend_args, env)
    new_commit_hash = run_git("rev-parse", "HEAD")

    restore_original = subprocess.run(
        ["git", "checkout", original_target],
        capture_output=True,
        text=True,
    )
    if restore_original.returncode != 0:
        print(
            "Error: amended the target commit, but failed to restore the "
            "original checkout state.",
            file=sys.stderr,
        )
        print(restore_original.stderr, file=sys.stderr)
        print(
            f"The rewritten commit is {new_commit_hash[:7]}.",
            file=sys.stderr,
        )
        sys.exit(1)

    rebase_result = subprocess.run(
        ["git", "rebase", "--onto", new_commit_hash, commit_hash],
        capture_output=True,
        text=True,
    )
    if rebase_result.returncode != 0:
        print(
            "Error: amended the target commit, but replaying descendant "
            "commits failed.",
            file=sys.stderr,
        )
        print(rebase_result.stderr, file=sys.stderr)
        print(
            "Resolve the rebase or abort it with 'git rebase --abort'.",
            file=sys.stderr,
        )
        sys.exit(1)

    return new_commit_hash


def compute_new_message_for_sign_off(args, commit_ref, sign_off_line):
    """Compute the new commit message for a sign-off operation.

    Returns the new message string if the message should change, or None if
    the commit already has the correct sign-off state and no change is needed.
    """
    body = get_commit_body(commit_ref)
    has_sign_off = commit_has_sign_off(commit_ref, sign_off_line)

    if args.sign_off and not has_sign_off:
        return add_sign_off_to_message(body, sign_off_line)
    elif args.remove_sign_off and has_sign_off:
        return remove_sign_off_from_message(body, sign_off_line)
    return None


def resolve_range_distances(start_ref, end_ref):
    """Resolve a commit range into (start_distance, end_distance) from HEAD.

    Both start_ref and end_ref must be ancestors of HEAD (or HEAD itself).
    start_distance >= end_distance (start is further back in history).
    The range is inclusive of both ends.

    Returns (start_distance, end_distance) where start_distance is the
    distance of the further-back commit and end_distance is the closer one.
    """
    start_hash = resolve_commit(start_ref)
    end_hash = resolve_commit(end_ref)

    ensure_commit_is_ancestor_of_head(start_hash)
    ensure_commit_is_ancestor_of_head(end_hash)

    start_dist = get_distance_from_head(start_hash)
    end_dist = get_distance_from_head(end_hash)

    # Normalize so that start_dist >= end_dist (start is further back)
    if start_dist < end_dist:
        start_dist, end_dist = end_dist, start_dist

    return start_dist, end_dist


def process_single_commit(args, commit_ref, sign_off_line, dry_run=False):
    """Process metadata changes for a single commit.

    Returns a dict with keys 'skipped' (bool), 'old_meta', 'new_meta'.
    For dry_run, new_meta is the projected meta and no writes are performed.
    """
    commit_hash = resolve_commit(commit_ref)
    old_meta = get_commit_meta(commit_hash)

    # Determine new message for sign-off operations
    new_message = None
    if args.sign_off or args.remove_sign_off:
        new_message = compute_new_message_for_sign_off(args, commit_hash, sign_off_line)
        # If no message change needed and no other modifications, skip this commit
        has_other_mods = any([
            args.date, args.author_date, args.committer_date,
            args.author, args.committer,
        ])
        if new_message is None and not has_other_mods:
            return {"skipped": True, "old_meta": old_meta, "new_meta": old_meta}

    amend_args, env, projected = build_amend_plan(args, old_meta, new_message=new_message)

    if dry_run:
        return {"skipped": False, "old_meta": old_meta, "new_meta": projected}

    if is_head(commit_hash):
        amend_head_with_plan(amend_args, env)
        new_meta = get_commit_meta("HEAD")
    else:
        new_commit_hash = rewrite_non_head_commit(commit_hash, amend_args, env)
        new_meta = get_commit_meta(new_commit_hash)

    return {"skipped": False, "old_meta": old_meta, "new_meta": new_meta}


def build_parser():
    parser = argparse.ArgumentParser(
        prog="git-commit-meta",
        description="View or modify git commit metadata (author, committer, dates, sign-off).",
        epilog=(
            "DATE can be: a git commit ref (copies author date from that commit), "
            "'now' (current time), or an ISO 8601 / git-parseable date string.\n\n"
            "AUTHOR/COMMITTER can be: a git ref (copies identity from that commit) "
            "or a 'Name <email>' string.\n\n"
            "Examples:\n"
            "  git-commit-meta --date now\n"
            "  git-commit-meta --date HEAD~1\n"
            "  git-commit-meta --date '2026-03-17T15:30:00-07:00'\n"
            "  git-commit-meta --author 'Jane Doe <jane@example.com>'\n"
            "  git-commit-meta --author HEAD~3\n"
            "  git-commit-meta --committer HEAD~3\n"
            "  git-commit-meta --show --commit HEAD~2\n"
            "  git-commit-meta --sign-off\n"
            "  git-commit-meta --remove-sign-off --commit HEAD~1\n"
            "  git-commit-meta --sign-off --range HEAD~3 HEAD\n"
            "  git-commit-meta --date now --range HEAD~4 HEAD~1\n"
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )

    parser.add_argument(
        "--commit",
        default="HEAD",
        metavar="COMMIT",
        help="Commit to modify (default: HEAD); ignored when --range is used",
    )

    range_group = parser.add_argument_group("range options")
    range_group.add_argument(
        "--range",
        nargs=2,
        metavar=("START", "END"),
        help=(
            "Apply changes to all commits in the inclusive range [START, END]. "
            "Both refs must be ancestors of HEAD (or HEAD itself) on the current branch. "
            "Cannot be combined with --show."
        ),
    )

    date_group = parser.add_argument_group("date options")
    date_group.add_argument(
        "-D", "--date",
        metavar="DATE",
        help="Set both author and committer date",
    )
    date_group.add_argument(
        "--author-date",
        metavar="DATE",
        help="Set only the author date",
    )
    date_group.add_argument(
        "--committer-date",
        metavar="DATE",
        help="Set only the committer date",
    )

    identity_group = parser.add_argument_group("identity options")
    identity_group.add_argument(
        "--author",
        metavar="AUTHOR",
        help='Set the author: "Name <email>" or a git ref to copy from',
    )
    identity_group.add_argument(
        "--committer",
        metavar="COMMITTER",
        help='Set the committer: "Name <email>" or a git ref to copy from',
    )

    signoff_group = parser.add_argument_group("sign-off options")
    signoff_group.add_argument(
        "--sign-off",
        action="store_true",
        help=(
            "Add a Signed-off-by trailer using the current git user.name and user.email. "
            "Skips commits that already have the sign-off."
        ),
    )
    signoff_group.add_argument(
        "--remove-sign-off",
        action="store_true",
        help=(
            "Remove the Signed-off-by trailer for the current git user. "
            "Skips commits that do not have the sign-off."
        ),
    )

    parser.add_argument(
        "--show",
        action="store_true",
        help="Show current metadata (default if no modification flags given)",
    )
    parser.add_argument(
        "-n", "--dry-run",
        action="store_true",
        help="Show what would change without doing it",
    )

    return parser


def main():
    parser = build_parser()
    args = parser.parse_args()

    # Validate mutually exclusive sign-off options
    if args.sign_off and args.remove_sign_off:
        print(
            "Error: --sign-off and --remove-sign-off cannot be used together.",
            file=sys.stderr,
        )
        sys.exit(1)

    if args.range and args.show:
        print("Error: --range cannot be combined with --show.", file=sys.stderr)
        sys.exit(1)

    # Check we're in a git repo
    rc, _ = run_git_rc("rev-parse", "--git-dir")
    if rc != 0:
        print("Error: not in a git repository.", file=sys.stderr)
        sys.exit(1)

    # Determine if any modifications were requested
    has_modifications = any([
        args.date,
        args.author_date,
        args.committer_date,
        args.author,
        args.committer,
        args.sign_off,
        args.remove_sign_off,
    ])

    # Resolve sign-off line early (needed for show, range, and single commit)
    sign_off_line = None
    if args.sign_off or args.remove_sign_off:
        user_name, user_email = get_git_user()
        sign_off_line = get_sign_off_line(user_name, user_email)

    # --- Range mode ---

    if args.range:
        if not has_modifications:
            print(
                "Error: --range requires at least one modification flag "
                "(e.g. --date, --sign-off).",
                file=sys.stderr,
            )
            sys.exit(1)

        start_ref, end_ref = args.range
        start_dist, end_dist = resolve_range_distances(start_ref, end_ref)

        if not args.dry_run:
            ensure_clean_worktree_for_history_rewrite()

        # Resolve any date/author args that reference git refs NOW, before we
        # start rewriting (the hashes will change during the loop).
        if args.date:
            args.date = resolve_date(args.date)
        if args.author_date:
            args.author_date = resolve_date(args.author_date)
        if args.committer_date:
            args.committer_date = resolve_date(args.committer_date)
        if args.author:
            name, email = resolve_author(args.author)
            args.author = f"{name} <{email}>"
        if args.committer:
            name, email = resolve_committer(args.committer)
            args.committer = f"{name} <{email}>"

        def dist_label(d):
            return "HEAD" if d == 0 else f"HEAD~{d}"

        print(
            f"Processing range {dist_label(start_dist)}..{dist_label(end_dist)} "
            f"({start_dist - end_dist + 1} commits):\n"
        )

        skipped_count = 0
        modified_count = 0

        # Iterate from furthest-back to closest so that after each rewrite the
        # next HEAD~N still refers to the correct (now-rebased) commit.
        for dist in range(start_dist, end_dist - 1, -1):
            commit_ref = f"HEAD~{dist}" if dist > 0 else "HEAD"
            commit_hash = resolve_commit(commit_ref)
            short_hash = commit_hash[:7]
            subject = run_git("log", "-1", "--format=%s", commit_ref)

            if args.dry_run:
                result = process_single_commit(
                    args, commit_ref, sign_off_line, dry_run=True
                )
                if result["skipped"]:
                    print(f"  skip  {short_hash} {subject}")
                    skipped_count += 1
                else:
                    print(f"  would modify  {short_hash} {subject}")
                    modified_count += 1
            else:
                result = process_single_commit(
                    args, commit_ref, sign_off_line, dry_run=False
                )
                if result["skipped"]:
                    print(f"  skip  {short_hash} {subject}")
                    skipped_count += 1
                else:
                    new_hash = run_git("rev-parse", f"HEAD~{dist}" if dist > 0 else "HEAD")
                    print(f"  ok    {short_hash} -> {new_hash[:7]} {subject}")
                    modified_count += 1

        print()
        if args.dry_run:
            print(f"Dry run: {modified_count} would be modified, {skipped_count} skipped.")
        else:
            print(f"Done: {modified_count} modified, {skipped_count} skipped.")
        return

    # --- Single-commit mode ---

    commit_hash = resolve_commit(args.commit)

    # If --show or no modifications, just display metadata
    if args.show or not has_modifications:
        meta = get_commit_meta(commit_hash)
        show_commit_meta(meta)
        return

    # Get current metadata for comparison and build the amend plan once.
    old_meta = get_commit_meta(commit_hash)

    # Determine new message for sign-off operations
    new_message = None
    if args.sign_off or args.remove_sign_off:
        new_message = compute_new_message_for_sign_off(args, commit_hash, sign_off_line)
        has_other_mods = any([
            args.date, args.author_date, args.committer_date,
            args.author, args.committer,
        ])
        if new_message is None and not has_other_mods:
            action = "already has" if args.sign_off else "does not have"
            print(
                f"Nothing to do: commit {commit_hash[:7]} {action} the sign-off."
            )
            return

    amend_args, env, projected = build_amend_plan(args, old_meta, new_message=new_message)

    # --- Dry run ---

    if args.dry_run:
        print("Dry run -- would make the following changes:\n")
        print("Before:")
        show_commit_meta(old_meta)
        print()
        print("After (projected):")
        show_commit_meta(projected)
        if new_message is not None:
            print("\nMessage would be changed (sign-off added/removed).")
        return

    # --- Execute the amend / rewrite ---

    if is_head(commit_hash):
        check_staged_changes()
        amend_head_with_plan(amend_args, env)
        new_meta = get_commit_meta("HEAD")
    else:
        ensure_clean_worktree_for_history_rewrite()
        ensure_commit_is_ancestor_of_head(commit_hash)
        new_commit_hash = rewrite_non_head_commit(commit_hash, amend_args, env)
        new_meta = get_commit_meta(new_commit_hash)

    # --- Show summary ---

    print("Modified commit metadata:\n")
    print("Before:")
    show_commit_meta(old_meta)
    print()
    print("After:")
    show_commit_meta(new_meta)
    show_changes(old_meta, new_meta)
    if new_message is not None:
        action = "added" if args.sign_off else "removed"
        print(f"Sign-off {action}.")


if __name__ == "__main__":
    main()
