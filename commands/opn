#!/usr/bin/env bash

if [[ "$@" =~ "--help" ]]; then
    echo "Usage: $0 <file>"
    echo "Open a file with the appropriate application, like xdg-open but with different configuration."
    exit 0
fi

source "$DOTFILESWGH/bazsh-lib"

openDefault() {
    if [[ "$1" == *.html
                || "$1" == *.htm
        ]]; then
        exec a ffxd "$1"
    elif [[ "$1" == *.pdf ]]; then
        exec a zathura "$1"
    elif [[ "$1" == *.mp3
                || "$1" == *.ogg
                || "$1" == *.flac
                || "$1" == *.aac
                || "$1" == *.mp4
                || "$1" == *.mkv
                || "$1" == *.mov
          ]]; then
        exec a vlc "$1"
    fi
}

openFuncs=()
# extend in other dotfiles by adding another function to openFuncs, which should exec on a match.
sourceFromDotfileswghAlts opn-conf.sh
openFuncs+=(openDefault)

for f in "${openFuncs[@]}"; do
    $f "$1"
done

exec a xdg-open "$1"
