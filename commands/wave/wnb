#!/usr/bin/env bash
# wnb -- Wave Native Build (thin wrapper around wave-dev-setup.sh)

set -euo pipefail

if [[ -n "${WAVE_DIR:-}" ]]; then
    : # use WAVE_DIR as-is
elif git rev-parse --show-toplevel &>/dev/null; then
    WAVE_DIR="$(git rev-parse --show-toplevel)"
else
    WAVE_DIR="$PWD"
fi
export WAVE_DIR

exec "$WAVE_DIR/build_tools/wave-dev-setup.sh" "$@"
