{
    "dockerfile": [
        {
            "text": [
                "#FROM ubuntu:24.04",
                "FROM ubuntu:25.10",
                "",
                "ENV DEBIAN_FRONTEND=noninteractive",
                "",
                "# Update package lists",
                "RUN apt-get update",
                "",
                "# Language tools specific to dev-misc",
                "RUN apt-get install -y --no-install-recommends racket",
                "RUN apt-get install -y --no-install-recommends guile-3.0",
                "RUN apt-get install -y --no-install-recommends python3",
                ""
            ]
        },
        {"text": "RUN apt-get install -y build-essential"},
        {"search": "dockerfile-components/dfcomp-apt-core-tools"},
        {"search": "dockerfile-components/dfcomp-apt-cpp-libs"},
        {"search": "dockerfile-components/dfcomp-nodejs-install"},
        {
            "text": [
                "# Rust toolchain for host tests and Android native libraries",
                "ARG RUST_TOOLCHAIN=1.97.1",
                "ARG CARGO_NDK_VERSION=4.1.2",
                "ENV RUSTUP_HOME=/opt/rustup",
                "ENV PATH=/opt/cargo/bin:$PATH",
                "RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | CARGO_HOME=/opt/cargo sh -s -- -y --no-modify-path --profile minimal --default-toolchain $RUST_TOOLCHAIN",
                "RUN CARGO_HOME=/opt/cargo rustup component add rustfmt clippy && \\",
                "    CARGO_HOME=/opt/cargo rustup target add aarch64-linux-android armv7-linux-androideabi x86_64-linux-android && \\",
                "    CARGO_HOME=/opt/cargo cargo install cargo-ndk --version $CARGO_NDK_VERSION --locked",
                ""
            ]
        },
        {"text": "RUN apt-get install -y bubblewrap"},
        {"search": "dockerfile-components/dfcomp-android-sdk"},
        {"search": "dockerfile-components/dfcomp-uv-install"},
        {"bash-print-text": "echo 'RUN useradd -u' $UID 'wgh \n RUN chsh -s /bin/zsh wgh'"},
        {"text": ""}
    ],
    "build-context-directory": "."
}
